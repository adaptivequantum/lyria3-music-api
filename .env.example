# ─── Lyria 3 Music API Configuration ─────────────────────────────────────

# Required: API key for authenticating requests
API_KEY=your-secure-api-key-here

# Port (default: 4000)
PORT=4000

# Cookie storage directory (default: ./cookies)
# On Render with persistent disk, set to /data/cookies
COOKIE_DIR=./cookies

# ─── Optional: S3 Storage for generated music files ──────────────────────
# If not set, files are served locally (not recommended for production)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ─── Optional: Custom upload endpoint ────────────────────────────────────
# POST file to this URL instead of S3
# UPLOAD_URL=https://your-app.com/api/upload
# UPLOAD_API_KEY=your-upload-key

# ─── Cookie Persistence (Render redeploy survival) ───────────────────────
# Base64-encoded JSON array of Google cookies.
# On startup, if no cookie file exists on disk, cookies are decoded from this
# env var and written to disk automatically — surviving all redeploys.
#
# How to generate the initial value:
#   python3 -c "import base64, open; print(base64.b64encode(open('google_cookies.json','rb').read()).decode())"
#
# Then set it in Render dashboard → Environment → GOOGLE_COOKIES_B64
# After that, every POST /api/cookies call will auto-update this env var.
# GOOGLE_COOKIES_B64=<base64-encoded-cookies-json>

# ─── Render API Integration (auto-update GOOGLE_COOKIES_B64 on upload) ───
# When POST /api/cookies is called, the new cookies are automatically saved
# to the GOOGLE_COOKIES_B64 env var on Render so the next redeploy loads them.
#
# Get your API key from: https://dashboard.render.com/u/settings/api-keys
# Get your service ID from the Render dashboard URL: /services/srv-XXXXXXXXXX
# RENDER_API_KEY=rnd_XXXXXXXXXXXXXXXXXXXXXXXXXX
# RENDER_SERVICE_ID=srv-XXXXXXXXXXXXXXXXXXXXXXXXXX
